#! /usr/bin/env python
# encoding: utf-8

def options(opt):
	return

def configure(conf):
	conf.load('fwgslib cxx11')

def build(bld):
	linkflags = []

	if bld.env.DEST_OS == 'android':
		linkflags += ['-lc++_shared']

	bld.shlib(
		source = ['vgui_menu.cpp'],
		target = 'menu_vgui',
		features = 'cxx cxxshlib',
		includes = [
			'.',
			'../mainui',
			'../mainui/sdk_includes/public',
			'../../common',
			'../../engine',
		],
		use = 'werror',
		linkflags = linkflags,
		install_path = bld.env.LIBDIR,
		cmake_skip = True
	)
